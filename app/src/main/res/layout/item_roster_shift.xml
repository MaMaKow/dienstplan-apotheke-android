<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeColor="#DDDDDD"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/textViewEmployeeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/textViewShiftTime"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/mitarbeiter_name"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageViewProfession"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:layout_toStartOf="@id/textViewShiftTime"
                android:layout_toEndOf="@id/textViewEmployeeName"
                android:contentDescription="@string/employee_profession_icon"
                app:tint="@color/profession_icon_tint" />

            <TextView
                android:id="@+id/textViewShiftTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text=""
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- rest unchanged -->
        <TextView
            android:id="@+id/textViewBranch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Filiale: Hauptapotheke"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textViewPause"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Pause: 12:00 - 13:00"
            android:textColor="#666666"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textViewComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#F5F5F5"
            android:padding="4dp"
            android:text="Kommentar"
            android:textSize="12sp"
            android:textStyle="italic"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>